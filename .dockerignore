# Prevent build artifacts from entering the Docker context.
# (kvrust is now cloned in the Dockerfile, not part of the build context.)

# Wakil binary (host-built, not needed in image)
wakil
wakil-old
wakil-*

# Python artifacts
__pycache__/
*.pyc
*.pyo

# Editor/OS noise
*.swp
*.swo
*~
.DS_Store

# Local config / secrets
config.json
.config/

# IDE
.idea/
.vscode/
.claude/

# Runtime artifacts
.wakil/
.tmp/
runs/
*.trace
*.jsonl.trace
